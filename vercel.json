{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd app && npm install && npm run build",
  "outputDirectory": "app/dist",
  "installCommand": "npm install --prefix app",
  "framework": null,
  "rewrites": [
    { "source": "/c/:path*", "destination": "/checkin.html" }
  ]
}
